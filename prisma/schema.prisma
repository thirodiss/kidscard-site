generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  GUARDIAN
  DEPENDENT
  ADMIN
}

enum AccountStatus {
  ACTIVE
  BLOCKED
  CLOSED
}

enum CardStatus {
  ACTIVE
  BLOCKED
  CANCELED
}

enum TransactionType {
  DEPOSIT
  TRANSFER_IN
  TRANSFER_OUT
  PURCHASE
  REFUND
  FEE
  ADJUSTMENT
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String?         @unique
  cpf            String          @unique
  passwordHash   String
  role           UserRole        @default(GUARDIAN)
  agency         String
  accountNumber  String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  walletAccounts WalletAccount[]
  dependents     Dependent[]     @relation("GuardianDependents")
}

model WalletAccount {
  id            String          @id @default(cuid())
  userId        String
  balanceCents  Int             @default(0)
  status        AccountStatus   @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards         Card[]
  transactions  Transaction[]
  dependents    Dependent[]
  transfers     Transfer[]
}

model Card {
  id                    String        @id @default(cuid())
  accountId             String
  holderName            String
  brand                 String        @default("Visa")
  last4                 String
  color                 String        @default("Midnight Blue")
  status                CardStatus    @default(ACTIVE)
  allowPhysicalPurchase Boolean       @default(true)
  allowOnlinePurchase   Boolean       @default(false)
  allowContactless      Boolean       @default(true)
  allowNotifications    Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  account               WalletAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String          @id @default(cuid())
  accountId     String
  type          TransactionType
  amountCents   Int
  description   String
  merchant      String?
  category      String?
  occurredAt    DateTime        @default(now())
  createdAt     DateTime        @default(now())

  account       WalletAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, occurredAt])
}

model Dependent {
  id                String        @id @default(cuid())
  guardianId        String
  accountId         String
  name              String
  cpf               String?       @unique
  birthDate         DateTime?
  monthlyLimitCents Int           @default(0)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  guardian          User          @relation("GuardianDependents", fields: [guardianId], references: [id], onDelete: Cascade)
  account           WalletAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transfers         Transfer[]
}

model Transfer {
  id            String        @id @default(cuid())
  fromAccountId String
  dependentId   String
  amountCents   Int
  note          String?
  createdAt     DateTime      @default(now())

  fromAccount   WalletAccount @relation(fields: [fromAccountId], references: [id], onDelete: Cascade)
  dependent     Dependent     @relation(fields: [dependentId], references: [id], onDelete: Cascade)

  @@index([fromAccountId, createdAt])
  @@index([dependentId, createdAt])
}